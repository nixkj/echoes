menu "WiFi Configuration"

config WIFI_SSID
    string "WiFi SSID"
    default "myssid"
    help
        SSID of the WiFi network

config WIFI_PASSWORD
    string "WiFi Password"
    default "mypassword"
    help
        Password of the WiFi network

endmenu

menu "Server Configuration"

config SERVER_IP
    string "Server IP Address"
    default "192.168.101.2"
    help
        IP address of the Raspberry Pi (or other host) running the three
        Echoes servers.  All three servers are assumed to run on the same
        host.  Change this to match your network before flashing.

        OTA firmware server   - http://<SERVER_IP>:8000
        Startup report server - http://<SERVER_IP>:8001
        Remote config server  - http://<SERVER_IP>:8002

config OTA_SERVER_PORT
    int "OTA Firmware Server Port"
    default 8000
    help
        TCP port for the OTA firmware server (firmware_server.py).
        Only change this if you have modified the server's default port.

config STARTUP_SERVER_PORT
    int "Startup Report Server Port"
    default 8001
    help
        TCP port for the startup report server (startup_server.py).
        Only change this if you have modified the server's default port.

config CONFIG_SERVER_PORT
    int "Remote Config Server Port"
    default 8002
    help
        TCP port for the remote configuration server (server.py).
        Only change this if you have modified the server's default port.

endmenu
