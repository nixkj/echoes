menu "WiFi Configuration"

config WIFI_SSID
    string "WiFi SSID"
    default "myssid"
    help
        SSID of the WiFi network

config WIFI_PASSWORD
    string "WiFi Password"
    default "mypassword"
    help
        Password of the WiFi network

endmenu

menu "Server Configuration"

config SERVER_IP
    string "Server IP Address"
    default "192.168.101.2"
    help
        IP address of the host running the consolidated Echoes server.

        All device traffic — OTA firmware, startup reports, and remote
        config — goes to a single process on SERVER_PORT (default 8002).

          GET  /firmware/version.txt   OTA version check
          GET  /firmware/echoes.bin    OTA binary download
          POST /startup                boot report
          GET  /config                 60-second parameter poll

config SERVER_PORT
    int "Server Port"
    default 8002
    help
        TCP port for the consolidated Echoes server.  All three services
        (OTA firmware, startup reports, remote config) are served from
        this single port.  Only change this if you have a specific reason
        to run the server on a different port.

endmenu
