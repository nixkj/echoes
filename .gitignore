# Build directories
/build/
/build-*/
/CMakeCache.txt
/CMakeFiles/
/compile_commands.json
/Makefile
/*.mk
/meson.build

# ESP-IDF specific
/sdkconfig
/sdkconfig.old
/sdkconfig.backup

# Editor temporary files
*~         # files ending with ~
*.un~      # any file ending with .un~
*.swp      # Vim swap files
*.swo      # Vim swap alternative
*.bak      # generic backup
*.tmp      # generic temporary
*.orig     # merge conflict backups

# Python caches
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# IDE/project files (if using VSCode or CLion)
.vscode/
.idea/
*.iml

# Logs and temporary files
*.log
*.tmp
